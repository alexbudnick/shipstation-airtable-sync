PORT=3000
LOG_LEVEL=info

# Airtable
AIRTABLE_PAT=PASTE_YOUR_AIRTABLE_PAT_HERE
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Inventory

AIRTABLE_SKU_FIELD=SKU
AIRTABLE_NAME_FIELD=Title
AIRTABLE_LOCATION_FIELD=Location
AIRTABLE_PRICE_FIELD=Price
AIRTABLE_QTY_FIELD=Qty On Hand
AIRTABLE_ACTIVE_FILTER_FIELD=Listed

# ShipStation
SHIPSTATION_API_BASE=https://ssapi.shipstation.com
SHIPSTATION_API_KEY=PASTE_YOUR_SHIPSTATION_API_KEY_HERE
SHIPSTATION_API_SECRET=PASTE_YOUR_SHIPSTATION_API_SECRET_HERE
SHIPSTATION_PAGE_SIZE=100
SHIPSTATION_MAX_PAGES=100

# Sync behavior
SYNC_TRIGGER_SECRET=replace_me
SYNC_ONLY_ACTIVE=true
DRY_RUN=false
